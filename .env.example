# =============================================================================
# KIRGO CONTROL TOWER — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already in .gitignore.
# =============================================================================

# --- Supabase Project ---
# Found in: Supabase Dashboard → Project Settings → API

# Your project URL (e.g. https://abcdefghij.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key — safe to expose in frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — NEVER expose in frontend; backend / data pipelines only
SUPABASE_SERVICE_ROLE_KEY=

# --- WooCommerce (Source data only — never stored in DB per BR-130, BR-133) ---
WOOCOMMERCE_URL=https://doriame.in
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# --- Shiprocket (Source data only) ---
SHIPROCKET_EMAIL=
SHIPROCKET_OTP=

# --- GoKwik (Source data only) ---
GOKWIK_EMAIL=
GOKWIK_PASSWORD=

# --- Google Ads ---
GOOGLE_ADS_ACCOUNT_ID=736-944-6064
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# --- Meta Ads ---
META_ADS_ACCOUNT_ID=729422043560314
META_ADS_ACCESS_TOKEN=
